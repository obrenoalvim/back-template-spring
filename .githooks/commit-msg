#!/bin/sh
# Conventional Commits check — same convention the JS templates enforce via commitlint,
# just a plain regex here since this is a Java repo with no Node toolchain.
set -e

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?: .+'
message=$(head -n1 "$1")

if ! echo "$message" | grep -qE "$pattern"; then
    echo "commit-msg: '$message' doesn't follow Conventional Commits."
    echo "Expected: type(scope?): subject — e.g. 'fix(auth): rotate refresh tokens on reuse'"
    echo "Types: feat fix docs style refactor perf test build ci chore revert"
    exit 1
fi
